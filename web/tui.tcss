/* Poker Evolution Dashboard TUI — Dark Theme, inspired by React frontend */

Screen {
    layout: vertical;
    overflow: hidden;
}

/* ── Header bar ── */
#header-bar {
    dock: top;
    height: 3;
    border-bottom: heavy $accent;
    padding: 0 2;
    content-align: center middle;
    color: $text;
    text-style: bold;
    background: $primary 15%;
}

/* ── Main area: 2-column ── */
#main-area {
    layout: horizontal;
    height: 1fr;
}

#left-col {
    width: 2fr;
    layout: vertical;
}

#right-col {
    width: 1fr;
    layout: vertical;
}

/* ── Pipeline bar ── */
#pipeline-bar {
    height: 3;
    border-bottom: hkey $primary;
    padding: 0 1;
    content-align: left middle;
    color: $text;
    text-style: bold;
    background: $surface-lighten-1;
}

/* ── LLM Stream ── */
#stream-panel {
    height: 2fr;
    layout: vertical;
}

#stream-log {
    border: round $primary;
    padding: 0 1;
    background: $surface-darken-1;
    scrollbar-size: 1 1;
}

/* ── History log ── */
#history-panel {
    height: 1fr;
    layout: vertical;
}

#history-log {
    border: round $secondary;
    padding: 0 1;
    scrollbar-size: 1 1;
}

/* ── Right column widgets ── */
#stats-bar {
    height: 4;
    border-bottom: hkey $primary;
    padding: 0 1;
    content-align: center middle;
    background: $surface-lighten-1;
}

#metrics-widget {
    height: 10;
    border: round $warning;
    padding: 0 1;
}

#cost-widget {
    height: auto;
    max-height: 14;
    border: round $primary;
    padding: 0 1;
}

#workers-widget {
    height: auto;
    max-height: 8;
    border: round $success;
    padding: 0 1;
}

#leaderboard-table {
    height: 1fr;
    border: round $primary;
}

#daemon-widget {
    height: 5;
    border: round $primary;
    padding: 0 1;
}

/* ── Base ── */
RichLog {
    scrollbar-size: 1 1;
}

DataTable {
    background: transparent;
}
